# Dev tempatan: Postgres local/Docker (rujuk PRD Seksyen 5.4).
# Prod/staging VPS guna host docker-internal: gerakops_pg (bukan localhost) —
# nilai sebenar disimpan /opt/xblpp/secrets/pg_app.env di server, BUKAN di sini.
DATABASE_URL=postgresql://xblpp_app:CHANGE_ME@localhost:5432/xblpp_dev

# Jangan hardcode domain dalam kod/email template — rujuk PRD Seksyen 5.6.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Auth.js v5 — jana dengan `npx auth secret`
AUTH_SECRET=

# Notification lib (src/lib/notify.ts) — kosongkan untuk guna stub (log ke
# console sahaja, tiada hantaran sebenar). Isi untuk live:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
TELEGRAM_BOT_TOKEN=
