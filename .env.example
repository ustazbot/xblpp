# Dev tempatan: Postgres local/Docker (rujuk PRD Seksyen 5.4).
# Prod/staging VPS guna host docker-internal: gerakops_pg (bukan localhost) —
# nilai sebenar disimpan /opt/xblpp/secrets/pg_app.env di server, BUKAN di sini.
DATABASE_URL=postgresql://xblpp_app:CHANGE_ME@localhost:5432/xblpp_dev

# Jangan hardcode domain dalam kod/email template — rujuk PRD Seksyen 5.6.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Nama container (docker-compose.yml `container_name`) — WAJIB padan dengan
# apa yang fail Caddy site (/opt/gerakops/caddy/sites/xblpp-{prod,staging}.caddy)
# `reverse_proxy` rujuk. TIADA port host di-publish — Caddy capai app terus
# melalui nama container atas network gerakops_net (rujuk nota docker-compose.yml).
CONTAINER_NAME=nextjs_xblpp_dev

# Auth.js v5 — jana dengan `npx auth secret`
AUTH_SECRET=

# Domain baharu blppkemas.com (subdomain aset./lms./apex, rujuk
# docs/runbook/deploy.md) — kosongkan dua-dua untuk domain lama (blpp.
# gerakops.com) atau dev tempatan, middleware.ts langkau logik subdomain
# terus (tiada perubahan tingkah laku).
# ROOT_DOMAIN: domain root sahaja (bukan URL penuh), cth "blppkemas.com".
ROOT_DOMAIN=
# COOKIE_DOMAIN: kongsi session antara aset./lms. — isi ".blppkemas.com"
# (dengan titik depan). Jangan isi kalau ROOT_DOMAIN kosong.
COOKIE_DOMAIN=

# Notification lib (src/lib/notify.ts) — kosongkan untuk guna stub (log ke
# console sahaja, tiada hantaran sebenar). Isi untuk live:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
TELEGRAM_BOT_TOKEN=
